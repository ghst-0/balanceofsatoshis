{
  "author": {
    "name": "Alex Bosworth",
    "url": "https://twitter.com/alexbosworth"
  },
  "bin": {
    "bos": "bos"
  },
  "bugs": {
    "url": "https://github.com/alexbosworth/balanceofsatoshis/issues"
  },
  "type": "module",
  "dependencies": {
    "@alexbosworth/blockchain": "3.2.0",
    "@alexbosworth/caporal": "workspace:*",
    "@alexbosworth/html2unicode": "1.1.5",
    "abort-controller": "3.0.0",
    "asciichart": "1.5.25",
    "async": "3.2.6",
    "asyncjs-util": "1.2.12",
    "bitcoinjs-lib": "6.1.7",
    "bolt01": "2.0.0",
    "bolt07": "1.9.4",
    "cbor": "10.0.11",
    "colorette": "2.0.20",
    "csv-parse": "6.1.0",
    "ecpair": "3.0.1",
    "hot-formula-parser": "4.0.0",
    "ini": "6.0.0",
    "inquirer": "13.2.5",
    "ln-accounting": "workspace:*",
    "ln-service": "workspace:*",
    "ln-sync": "workspace:*",
    "ln-telegram": "workspace:*",
    "minimist": "1.2.8",
    "moment": "2.30.1",
    "sanitize-filename": "1.6.3",
    "table": "6.9.0",
    "tiny-secp256k1": "2.2.4"
  },
  "description": "Lightning balance CLI",
  "devDependencies": {
    "oxlint": "^1.49.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "cli",
    "lightning",
    "lightning-network",
    "lnd"
  ],
  "license": "MIT",
  "main": "index.js",
  "name": "balanceofsatoshis",
  "repository": {
    "type": "git",
    "url": "https://github.com/alexbosworth/balanceofsatoshis.git"
  },
  "scripts": {
    "integration-tests": "node test/integration",
    "postpack": "PACKAGE_VERSION=$(cat package.json | grep \\\"version\\\" | head -1 | awk -F: '{ print $2 }' | sed 's/[\",]//g' | tr -d '[[:space:]]') && git tag -s v$PACKAGE_VERSION -m v$PACKAGE_VERSION && git push github --tags",
    "test": "node --experimental-test-coverage --test test/arrays/*.js test/balances/*.js test/chain/*.js test/display/*.js test/encryption/*.js test/lnd/*.js test/network/*.js test/nodes/*.js test/peers/*.js test/responses/*.js test/routing/*.js test/services/*.js test/tags/*.js test/telegram/*.js test/wallets/*.js"
  },
  "version": "20.0.2",
  "pnpm": {
    "overrides": {
      "@oxlint/binding-android-arm-eabi": "-",
      "@oxlint/binding-linux-arm-gnueabihf": "-",
      "@oxlint/binding-linux-arm64-musl": "-",
      "@oxlint/binding-linux-arm64-gnu": "-",
      "@oxlint/binding-win32-arm64-msvc": "-",
      "@oxlint/binding-darwin-arm64": "-",
      "@oxlint/binding-android-arm64": "-",
      "@oxlint/binding-openharmony-arm64": "-",
      "@oxlint/binding-linux-riscv64-musl": "-",
      "@oxlint/binding-linux-ppc64-gnu": "-",
      "@oxlint/binding-win32-ia32-msvc": "-",
      "@oxlint/binding-win32-x64-msvc": "-",
      "@oxlint/binding-linux-arm-musleabihf": "-",
      "@oxlint/binding-linux-x64-musl": "-",
      "@oxlint/binding-linux-riscv64-gnu": "-",
      "@oxlint/binding-darwin-x64": "-",
      "@oxlint/binding-linux-s390x-gnu": "-",
      "@oxlint/binding-freebsd-x64": "-"
    }
  }
}
